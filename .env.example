# Загальні налаштування середовища
NODE_ENV=development
PORT=3000

# Конфігурація Twenty CRM URL
SERVER_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Криптографічна безпека архітектури підприємства
# Увага: ENCRYPTION_KEY повинен бути випадковим 64-символьним Hex-рядком
ENCRYPTION_KEY=your_generate_64_character_hex_key_for_data_encryption
JWT_SECRET=your_secure_jwt_secret_token_here

# Атомарні змінні доступу до СКБД (Єдине джерело правди)
DB_USER=twenty_admin
DB_PASSWORD=your_secure_database_password_here
DB_NAME=twenty_crm

# Шар збереження даних
PG_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# Сховище для файлів (локальне / s3)
STORAGE_TYPE=local

# Параметри Redis (Шар кешування та черг повідомлень)
REDIS_URL=redis://redis:6379